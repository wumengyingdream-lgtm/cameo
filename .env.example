# Cameo — optional signing config for release builds. Copy to `.env` and fill in.
# `.env` is gitignored. Leave everything blank for unsigned local/test builds.
#
# Only `build_release.sh` (macOS) and `build_release.ps1` (Windows) read this.
# Dev builds (`build_dev.*`, `pnpm tauri dev`) never sign.

# ── macOS code signing (Developer ID) ────────────────────────────────────────
# From your keychain: `security find-identity -v -p codesigning`
APPLE_SIGNING_IDENTITY="Developer ID Application: YOUR NAME (TEAMID)"

# ── macOS notarization — choose ONE of the two blocks below ───────────────────
# (A) App Store Connect API key (recommended):
APPLE_API_KEY=""           # Key ID, e.g. ABCD1234EF
APPLE_API_ISSUER=""        # Issuer UUID
APPLE_API_KEY_PATH=""      # path to AuthKey_XXXX.p8

# (B) Apple ID + app-specific password:
# APPLE_ID=""
# APPLE_PASSWORD=""         # app-specific password
# APPLE_TEAM_ID=""

# ── Windows code signing ──────────────────────────────────────────────────────
# Windows signing is configured in src-tauri/tauri.conf.json
# (bundle.windows.certificateThumbprint or signCommand), not here.

# ── Cloud features (Gallery + telemetry) — OFFICIAL builds only ──────────────
# Vite inlines both vars into the bundle at build time. When EITHER is missing
# the cloud module short-circuits: Gallery button hidden, telemetry never sends,
# Cameo runs as a pure local tool. Open-source self-builds simply leave these
# blank.
# (Official Cameo builds set these; open-source self-builds leave them blank.)
VITE_CAMEO_API_BASE="https://cameo.ink"
VITE_CAMEO_API_KEY=""

# ── Tauri update signing (ed25519) — OFFICIAL builds only ────────────────────
# Generate once with `pnpm tauri signer generate --write-keys ~/.tauri/cameo`
# then paste the contents of the private-key file (~/.tauri/cameo) below.
# The public-key counterpart belongs in src-tauri/tauri.conf.json's
# `plugins.updater.pubkey`. **Back up the private key offline** — losing it
# permanently breaks the update path for every installed copy of Cameo.
TAURI_SIGNING_PRIVATE_KEY=""
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""

# ── R2 release upload — OFFICIAL builds only ─────────────────────────────────
# Used by publish_release.sh (macOS) and publish_release.ps1 (Windows) to push
# release artifacts to the Cloudflare R2 bucket behind https://r.cameo.ink:
# signed auto-update payloads + updater manifests, website download manifests
# (latest.json / latest_win.json), and the installer files those manifests
# reference. The two scripts run independently on each platform's build machine,
# so BOTH machines need these in their own .env. Self-builds that don't publish
# official releases can leave them blank.
#
# R2 → "Manage R2 API Tokens" gives the key pair; the endpoint is the
# S3-compatible URL https://<accountid>.r2.cloudflarestorage.com.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""             # https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=""               # e.g. cameo-releases

# ── Cloudflare cache purge after release upload (optional, recommended) ──────
# If set, publish_release.* purges the just-uploaded R2 URLs so latest*.json and
# updater manifests are visible immediately through the custom domain.
CF_ZONE_ID=""
CF_API_TOKEN=""            # needs Zone.Cache Purge permission
