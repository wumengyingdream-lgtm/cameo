{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cameo",
  "version": "0.1.1",
  "identifier": "com.cameo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cameo",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#FAFAFA",
        "trafficLightPosition": { "x": 16, "y": 18 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3QkFFQzI0QzZFODk0RkEKUldUNmxPakdKT3k2UjhVQURTWDgxVmFTRGVHaVVtLzRlZFBIWUZKS0dsYmtzakZMbU5mdFFmaCsK",
      "endpoints": [
        "https://r.cameo.ink/update/{{target}}-{{arch}}.json"
      ]
    }
  }
}
